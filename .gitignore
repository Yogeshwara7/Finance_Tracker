# =============================================================
# Innorve — Round 1 Submissions | Root .gitignore
# =============================================================
# This file prevents common junk and sensitive files from being
# committed. Candidates should also add a .gitignore inside
# their own folder for project-specific exclusions.
# =============================================================


# ── Secrets & Environment Variables ──────────────────────────
# Never commit credentials, API keys, or tokens
.env
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json


# ── Node / JavaScript ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
.next/
dist/
build/
.cache/


# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.env/
*.egg-info/
dist/
*.dist-info/
.pytest_cache/


# ── Power Platform / Microsoft ───────────────────────────────
# Exclude auto-generated Power Apps / Power Automate temp files
*.msapp.bak
~$*.xlsx
~$*.docx
~$*.pptx
Thumbs.db:encryptable


# ── Operating System ─────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ── IDE & Editors ─────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
.project
.classpath
.settings/


# ── Logs & Temp Files ─────────────────────────────────────────
*.log
*.tmp
*.temp
*.bak
*.backup
.temp/
tmp/


# ── Compiled / Binary Output ──────────────────────────────────
*.exe
*.dll
*.so
*.dylib
*.class
*.o
*.out


# ── Archives ──────────────────────────────────────────────────
# Zip exports are allowed (e.g. Power Apps .msapp, Kore.ai exports)
# but exclude generic compressed junk
*.tar
*.tar.gz
*.rar
*.7z


# ── Database ──────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db


# ── Package Manager Locks (optional — candidates may include these) ──
# Uncomment the lines below if you want to exclude lock files
# package-lock.json
# yarn.lock
